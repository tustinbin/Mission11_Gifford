{
  "openapi": "3.1.1",
  "info": {
    "title": "backend | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:5000"
    },
    {
      "url": "http://localhost:4000"
    }
  ],
  "paths": {
    "/api/Book/AllBooks": {
      "get": {
        "tags": [
          "Book"
        ],
        "parameters": [
          {
            "name": "pageHowMany",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 10
            }
          },
          {
            "name": "pageNum",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "sortTitleAsc",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Book"
    }
  ]
}